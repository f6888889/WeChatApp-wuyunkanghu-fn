.page {
  min-height: 100vh;
  background-color: #FDF6EC;
  padding: 40rpx;
  box-sizing: border-box;
}

/* Header style */
.podcast-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}



.title-section {
  text-align: center;
  padding: 0 20rpx;
}

.podcast-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #3D2C2E;
  line-height: 1.4;
  margin-bottom: 16rpx;
  display: block;
}

.meta-info {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  align-items: center;
}

.duration-tag {
  font-size: 26rpx;
  color: #8B7D7B;
}

/* Player Panel */
.player-panel {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(61, 44, 46, 0.05);
  margin-bottom: 48rpx;
}

.progress-wrap {
  width: 100%;
  margin-bottom: 32rpx;
}

.progress-slider {
  margin: 0;
  padding: 10rpx 0;
}

.time-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.time-label {
  font-size: 24rpx;
  color: #8B7D7B;
  font-family: monospace;
}

.control-actions {
  display: flex;
  justify-content: center;
  align-items: center;
}

.play-btn {
  width: 120rpx !important;
  height: 120rpx !important;
  border-radius: 50% !important;
  background: #E07A5F !important;
  padding: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(224, 122, 95, 0.35);
  transition: transform 0.2s ease, background-color 0.2s ease;
}

.play-btn:active {
  transform: scale(0.95);
  background: #d06a4f !important;
}

.play-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  color: #FFFFFF;
  font-size: 48rpx;
  font-weight: bold;
  margin-left: 6rpx; /* Align play triangle slightly to center */
}

.play-btn.playing .play-icon {
  margin-left: 0;
}

/* Content Body */
.podcast-body {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(61, 44, 46, 0.05);
}

.section-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 8rpx;
}

.title-line {
  width: 60rpx;
  height: 6rpx;
  background: #E07A5F;
  border-radius: 3rpx;
}

.content-blocks {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.text-paragraph {
  font-size: 30rpx;
  color: #4A3E3D;
  line-height: 1.6;
  text-align: justify;
}

