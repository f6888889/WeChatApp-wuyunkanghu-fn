.page {
  min-height: 100vh;
  background: #FDF6EC;
  padding: 40rpx;
}

.header {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #8B7D7B;
}

.upload-section {
  margin-bottom: 48rpx;
}

.video-uploader {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(61, 44, 46, 0.1);
  border: 2rpx dashed #E07A5F;
}

.upload-icon {
  font-size: 96rpx;
}

.upload-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.upload-hint {
  font-size: 24rpx;
  color: #8B7D7B;
}

.video-preview {
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(61, 44, 46, 0.1);
}

.preview-video {
  width: 100%;
  height: 450rpx;
}

.video-actions {
  padding: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.reselect-btn {
  background: #f5f5f5;
  color: #3D2C2E;
  font-size: 26rpx;
  border-radius: 20rpx;
  padding: 12rpx 32rpx;
  border: none;
}

.reselect-btn::after {
  border: none;
}

.form-section {
  margin-bottom: 48rpx;
}

.form-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(61, 44, 46, 0.1);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #3D2C2E;
  background: #FDF6EC;
  border-radius: 16rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #3D2C2E;
  background: #FDF6EC;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  line-height: 1.6;
}

.upload-btn-section {
  margin-top: 48rpx;
}

.upload-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #E07A5F 0%, #D06A4F 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(224, 122, 95, 0.3);
}

.upload-btn::after {
  border: none;
}

.upload-btn[disabled] {
  opacity: 0.6;
}

.upload-btn.uploading {
  opacity: 0.8;
}

/* Safe Mode Styles */
.safe-section {
  margin-bottom: 48rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.section-count {
  font-size: 24rpx;
  color: #8B7D7B;
}

.safe-articles-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.safe-article-card {
  background: #F8E8D6;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.08);
  display: flex;
  flex-direction: column;
}

.safe-article-cover {
  width: 100%;
  height: 350rpx;
}

.safe-article-content {
  padding: 30rpx;
}

.safe-article-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 20rpx;
  display: block;
}

.safe-article-desc {
  font-size: 28rpx;
  color: #5C5251;
  line-height: 1.8;
  text-align: justify;
}
