.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #E53935 0%, #FF5722 100%);
  padding: 40rpx 30rpx;
  text-align: center;
  color: white;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

.content {
  padding: 30rpx;
}

.form-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
}

.form-item-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: -20rpx;
}

.alert-preview {
  margin-bottom: 30rpx;
}

.preview-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 10rpx;
}

.preview-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 8rpx solid #FF9800;
}

.preview-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.preview-type {
  font-size: 26rpx;
  color: #FF9800;
  font-weight: bold;
}

.preview-body {
  margin-bottom: 16rpx;
}

.preview-message {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.preview-footer {
  text-align: right;
}

.preview-time {
  font-size: 22rpx;
  color: #999;
}

.tips-section {
  background: #FFF8E1;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 120rpx;
}

.tips-title {
  display: block;
  font-size: 28rpx;
  color: #F57C00;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.tips-list {
  display: flex;
  flex-direction: column;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #E53935 0%, #FF5722 100%);
  color: white;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  border: none;
}