.page {
  min-height: 100vh;
  background-color: var(--background);
  position: relative;
  padding-bottom: 40rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-top: 24rpx;
}

.content {
  padding: 0 40rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-title {
  font-size: 36rpx;
  color: var(--text-dark);
  margin-top: 40rpx;
  font-weight: bold;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
  margin-bottom: 60rpx;
}

.action-btn {
  background: var(--primary);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  padding: 24rpx 80rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(224, 122, 95, 0.4);
}

.action-btn::after {
  border: none;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 20rpx;
}

.course-card {
  background: var(--white);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.08);
  transition: transform 0.2s ease;
}

.course-card:active {
  transform: scale(0.98);
}

.course-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: var(--card-bg);
}

.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.course-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-dark);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meta-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-easy {
  background: #E8F5E9;
  color: #4CAF50;
}

.tag-medium {
  background: #FFF3E0;
  color: #FF9800;
}

.tag-hard {
  background: #FFEBEE;
  color: #F44336;
}

.course-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
}
