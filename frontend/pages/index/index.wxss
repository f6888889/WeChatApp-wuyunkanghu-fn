.page {
  min-height: 100vh;
  background-color: #FDF6EC;
  position: relative;
}

.noise-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  z-index: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx;
  position: relative;
  z-index: 1;
}

.greeting-section {
  display: flex;
  flex-direction: column;
}

.greeting-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.greeting-sub {
  font-size: 28rpx;
  color: #8B7D7B;
  margin-top: 8rpx;
}

.header-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #E07A5F;
}

.main-content {
  padding: 0 40rpx 40rpx;
  position: relative;
  z-index: 1;
}

.featured-card {
  background: #F8E8D6;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(61, 44, 46, 0.12);
  margin-bottom: 40rpx;
}

.featured-label {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: #E07A5F;
  color: white;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  z-index: 2;
}

.featured-image {
  width: 100%;
  height: 360rpx;
}

.featured-info {
  padding: 24rpx;
}

.featured-title {
  font-size: 38rpx;
  font-weight: bold;
  color: #3D2C2E;
  display: block;
  margin-bottom: 12rpx;
}

.featured-desc {
  font-size: 28rpx;
  color: #8B7D7B;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.progress-section {
  margin-bottom: 40rpx;
}

.progress-card {
  background: #F8E8D6;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(61, 44, 46, 0.08);
}

.progress-divider {
  width: 2rpx;
  height: 100rpx;
  background: rgba(139, 125, 123, 0.2);
  flex-shrink: 0;
}

.progress-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.progress-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #E07A5F;
}

.progress-label {
  font-size: 24rpx;
  color: #8B7D7B;
  margin-top: 4rpx;
}

.all-courses-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.section-count {
  font-size: 26rpx;
  color: #8B7D7B;
}

.courses-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.course-card {
  background: #F8E8D6;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  position: relative;
  min-height: 150rpx;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.08);
}

.course-cover {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 200rpx;
  height: 100%;
}

.course-card-info {
  flex: 1;
  margin-left: 200rpx;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.course-card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.course-card-desc {
  font-size: 24rpx;
  color: #8B7D7B;
  line-height: 1.4;
}

.line-clamp-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

/* Safe Mode Styles */
.safe-articles-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.safe-article-card {
  background: #F8E8D6;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.08);
  display: flex;
  flex-direction: column;
}

.safe-article-cover {
  width: 100%;
  height: 350rpx;
}

.safe-article-content {
  padding: 30rpx;
}

.safe-article-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 20rpx;
  display: block;
}

.safe-article-desc {
  font-size: 28rpx;
  color: #5C5251;
  line-height: 1.8;
  text-align: justify;
}

/* 分页控件样式 */
.pagination-container {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 40rpx;
  gap: 16rpx;
}

.page-btn {
  font-size: 26rpx;
  color: #E07A5F;
  background-color: #FFFFFF;
  border: 1rpx solid rgba(224, 122, 95, 0.3);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(224, 122, 95, 0.05);
  transition: all 0.2s ease;
}

.page-btn:active {
  background-color: #F8E8D6;
  transform: scale(0.95);
}

.page-btn.disabled {
  color: #C0B7B5;
  background-color: #F3ECE2;
  border-color: rgba(192, 183, 181, 0.3);
  box-shadow: none;
  pointer-events: none;
}

.page-num {
  width: 60rpx;
  height: 60rpx;
  font-size: 28rpx;
  color: #8B7D7B;
  background-color: #FFFFFF;
  border: 1rpx solid rgba(139, 125, 123, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(61, 44, 46, 0.03);
  transition: all 0.2s ease;
}

.page-num:active {
  transform: scale(0.92);
}

.page-num.active {
  color: #FFFFFF;
  background-color: #E07A5F;
  border-color: #E07A5F;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(224, 122, 95, 0.3);
}
