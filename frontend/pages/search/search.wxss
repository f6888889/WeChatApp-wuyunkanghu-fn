.page {
  min-height: 100vh;
  background-color: #FDF6EC;
  position: relative;
}

.search-header {
  padding: 30rpx 40rpx;
  position: relative;
  z-index: 10;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(61, 44, 46, 0.1);
  flex-wrap: wrap;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  min-width: 200rpx;
  font-size: 32rpx;
  color: #3D2C2E;
  height: 56rpx;
}

.search-placeholder {
  color: #8B7D7B;
  font-size: 32rpx;
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.voice-btn,
.send-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  background: #E07A5F;
  border-radius: 24rpx;
  color: white;
  min-width: 100rpx;
}

.voice-btn.recording {
  background: #ff4d4f;
}

.btn-text {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.search-content {
  padding: 0 40rpx 40rpx;
}

.results-section {
  padding: 0 40rpx 40rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.results-count {
  font-size: 28rpx;
  color: #8B7D7B;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-item {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.06);
}



.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3D2C2E;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #8B7D7B;
  line-height: 1.5;
  flex: 1;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #8B7D7B;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-state .empty-icon {
  color: #8B7D7B;
  opacity: 0.5;
  font-size: 120rpx;
}

.empty-text {
  font-size: 36rpx;
  color: #3D2C2E;
  margin-top: 32rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #8B7D7B;
  margin-top: 16rpx;
}

.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(253, 246, 236, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 100rpx;
  height: 100rpx;
  border: 8rpx solid rgba(224, 122, 95, 0.2);
  border-top-color: #E07A5F;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #8B7D7B;
  margin-top: 24rpx;
}

.courses-section {
  margin-bottom: 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-count {
  font-size: 28rpx;
  color: #8B7D7B;
}

.ai-section {
  margin-top: 20rpx;
}

.ai-response-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(61, 44, 46, 0.06);
}

.ai-content {
  flex: 1;
}

.ai-text {
  font-size: 30rpx;
  color: #3D2C2E;
  line-height: 1.6;
}

.ai-avatar-wrap {
  width: 80rpx;
  height: 80rpx;
  background-color: #FEEFDD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 10rpx rgba(224, 122, 95, 0.15);
}

.ai-avatar-icon {
  font-size: 44rpx;
}



/* Result item active states */
.result-item:active {
  transform: scale(0.98);
  opacity: 0.92;
  background-color: #FAF2E8;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #3D2C2E;
}

.all-podcasts-section {
  padding: 0 40rpx 40rpx;
}

.ai-loading {
  color: #8B7D7B;
  font-style: italic;
  animation: breathe 1.5s infinite ease-in-out;
}

@keyframes breathe {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.podcast-searching-inline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx 0;
  margin-top: 30rpx;
}

.inline-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(224, 122, 95, 0.2);
  border-top-color: #E07A5F;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.inline-loading-text {
  font-size: 28rpx;
  color: #8B7D7B;
}

