.page {
  min-height: 100vh;
  background-color: #F8F9FA;
  padding-bottom: 60rpx;
}

.points-header {
  padding: 40rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #F8F9FA;
}

.points-banner {
  background: linear-gradient(135deg, #E07A5F 0%, #F2A07B 100%);
  border-radius: 32rpx;
  padding: 40rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 16rpx 48rpx rgba(224, 122, 95, 0.25);
  position: relative;
  overflow: hidden;
}

.points-banner::after {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.points-banner-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.points-banner-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
}

.points-banner-info {
  display: flex;
  flex-direction: column;
}

.points-banner-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}

.points-banner-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

.policy-notice {
  padding: 0 40rpx 30rpx;
}

.policy-notice-content {
  background: rgba(224, 122, 95, 0.08);
  border: 1rpx solid rgba(224, 122, 95, 0.2);
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.policy-icon {
  font-size: 32rpx;
}

.policy-text {
  font-size: 24rpx;
  color: #E07A5F;
  font-weight: 500;
  line-height: 1.4;
}

.category-tabs {
  display: flex;
  padding: 0 40rpx 30rpx;
  gap: 20rpx;
  overflow-x: auto;
}

.tab-item {
  padding: 16rpx 40rpx;
  border-radius: 50rpx;
  background: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  color: #6C757D;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  white-space: nowrap;
}

.tab-item.active {
  background: #3D405B;
  color: #FFFFFF;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(61, 64, 91, 0.2);
  transform: translateY(-2rpx);
}

.shop-list {
  padding: 0 40rpx;
}

.shop-item {
  margin-bottom: 40rpx;
  animation: fadeInUp 0.6s ease-out both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.item-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

.item-image {
  width: 100%;
  height: 380rpx;
  transition: transform 0.5s ease;
}

.item-category-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10rpx);
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: bold;
  color: #3D405B;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.item-info {
  padding: 32rpx;
}

.item-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 12rpx;
}

.item-desc {
  font-size: 26rpx;
  color: #636E72;
  display: block;
  margin-bottom: 30rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #F1F3F5;
  padding-top: 24rpx;
}

.item-points {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.item-points-icon {
  font-size: 28rpx;
}

.item-points-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #E07A5F;
}

.redeem-btn {
  background: linear-gradient(135deg, #81B29A 0%, #67927D 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 40rpx;
  padding: 14rpx 40rpx;
  margin: 0;
  line-height: 1.5;
  box-shadow: 0 6rpx 16rpx rgba(129, 178, 154, 0.3);
  transition: all 0.2s ease;
}

.redeem-btn.disabled {
  background: #E9ECEF;
  color: #ADB5BD;
  box-shadow: none;
}

.redeem-btn.redeemed {
  background: #3D405B;
  box-shadow: 0 6rpx 16rpx rgba(61, 64, 91, 0.2);
}

.redeem-btn:active:not(.disabled) {
  transform: scale(0.96);
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  color: #ADB5BD;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #6C757D;
  font-size: 28rpx;
  gap: 16rpx;
}

.loading::before {
  content: '';
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #E07A5F;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

