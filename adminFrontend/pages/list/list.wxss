.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.add-btn {
  width: 160rpx;
  height: 70rpx;
  line-height: 70rpx;
  font-size: 26rpx;
}

.search-box {
  margin-bottom: 30rpx;
}

.search-input {
  background: #fff;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
}

.item-id {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
}

.edit-btn {
  background: #f0f7ff;
  color: #007aff;
}

.delete-btn {
  background: #fff1f0;
  color: #ff4d4f;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #ccc;
  font-size: 28rpx;
}
