<view class="container">
  <view class="header">
    <view class="title">管理系统</view>
    <view class="subtitle">选择数据进行管理</view>
  </view>

  <view class="menu-grid">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="type" bindtap="goToPath" data-type="{{item.type}}" data-name="{{item.name}}">
      <view class="menu-icon">{{item.icon}}</view>
      <view class="menu-name">{{item.name}}</view>
      <view class="menu-desc">{{item.desc}}</view>
    </view>
  </view>
</view>
